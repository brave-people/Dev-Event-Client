useSelector<ReducerType>((state) => state.list) as {\n    years: string[];\n  };\n  const dispatch = useDispatch();\n\n  function setUpdateYears(value: string) {\n    dispatch(updateYears(value));\n  }\n\n  const filterCardListData: ListModel[] = CardListData.filter((card) => {\n    return years.find((v) => {\n      // 선택한 years에 부합하는 조건 찾기\n      if (\n        card.startDate.split(\".\")[0] === v ||\n        card.endDate.split(\".\")[0] === v\n      ) {\n        return card;\n      }\n    });\n  }).sort(\n    // 날짜와 시 순으로 정렬\n    (a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime()\n  );\n\n  return (\n    <section className={\"filter__box list__filter__box\"}>\n      <article className={\"filter__button__wrap\"}>\n        <button\n          className={\n            years.findIndex((v) => v === \"2020\") > -1\n              ? \"filter__button filter__button--active\"\n              : \"filter__button\"\n          }\n          onClick={() => setUpdateYears(\"2020\")}\n        >\n          2020\n        </button>\n        <button\n          className={\n            years.findIndex((v) => v === \"2021\") > -1\n              ? \"filter__button filter__button--active\"\n              : \"filter__button\"\n          }\n          onClick={() => setUpdateYears(\"2021\")}\n        >\n          2021\n        </button>\n      </article>\n      <ListCard cards={years.length ? filterCardListData : CardListData} />\n    </section>\n  );\n}\n\nexport default PastEvent;\n",{"ruleId":"58","replacedBy":"59"},{"ruleId":"60","replacedBy":"61"},{"ruleId":"58","replacedBy":"62"},{"ruleId":"60","replacedBy":"63"},{"ruleId":"58","replacedBy":"64"},{"ruleId":"60","replacedBy":"65"},{"ruleId":"66","severity":1,"message":"67","line":38,"column":49,"nodeType":"68","messageId":"69","endLine":38,"endColumn":51},{"ruleId":"58","replacedBy":"70"},{"ruleId":"60","replacedBy":"71"},{"ruleId":"72","severity":1,"message":"73","line":14,"column":9,"nodeType":"74","endLine":14,"endColumn":101},{"ruleId":"66","severity":1,"message":"75","line":20,"column":27,"nodeType":"68","messageId":"69","endLine":20,"endColumn":29},"no-native-reassign",["76"],"no-negated-in-lhs",["77"],["76"],["77"],["76"],["77"],"array-callback-return","Array.prototype.filter() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd",["76"],["77"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","Array.prototype.find() expects a value to be returned at the end of arrow function.","no-global-assign","no-unsafe-negation"]